APP_NAME=DataReaper Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=console
APP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
APP_SECRET_KEY=change-me
APP_ENABLE_DEMO_MODE=false
APP_AUTO_CREATE_TABLES=true

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key

DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres
SYNC_DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres

REDIS_URL=redis://localhost:6379/0
ARQ_REDIS_URL=redis://localhost:6379/0

LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key_here
BRAVE_SEARCH_API_KEY=
GITHUB_API_TOKEN=
SERP_API_KEY=
PROXYCURL_API_KEY=
DEFAULT_JURISDICTION=DPDP

GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_SENDER_EMAIL=

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_PROXY_SERVER=
LOCAL_STORAGE_PATH=./storage
OSINT_ENABLE_PLAYWRIGHT_LAYERS=false
OSINT_ENABLE_PLATFORM_BROWSER_FALLBACK=false
OSINT_ENABLE_SEARCH_PROBE=false
OSINT_ENABLE_DUCKDUCKGO_FALLBACK=false
OSINT_ENABLE_PASTE_SEARCH=false
OSINT_ENABLE_MAIGRET=true
OSINT_ENABLE_TRAFILATURA=true
OSINT_DEBUG_EVENTS=false
OSINT_PLATFORM_PROBE_CANDIDATES=75
OSINT_MAIGRET_CANDIDATES=8
OSINT_MAIGRET_TOP_SITES=150
OSINT_MAIGRET_MAX_CONNECTIONS=24
